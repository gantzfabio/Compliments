/* IMPORTANTE: não mexer na estrutura base da .menu */
.menu {
  display: block;
}

/* GRID apenas para menus ativos */
.menu .main-menu,
.menu .power-menu,
.menu .settings-menu,
.menu .edit-menu {
  display: none;
}

/* quando ativo */
.menu .main-menu.active,
.menu .power-menu.active,
.menu .settings-menu.active,
.menu .edit-menu.active {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
  padding: 10px;
}

/* estilo dos botões */
.menu-element {
  border-radius: 28px;
  height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 16px;
  font-weight: 500;
  color: white;
  background: #1c1c1e;
  transition: all 0.2s ease;
}

.menu-element:active {
  transform: scale(0.96);
