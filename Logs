/* Base iOS style */
body {
  background: #0b0d12 !important;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", Roboto;
  margin: 0;
}

/* Container central */
.container {
  padding: 16px;
}

/* Título */
h1 {
  font-size: 14px;
  font-weight: 600;
  opacity: 0.5;
  letter-spacing: 1px;
  margin-bottom: 12px;
}

/* Lista */
ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

/* Item vira um CARD */
li {
  margin-bottom: 12px;
}

/* Botão estilo iOS */
li a {
  display: flex;
  align-items: center;
  justify-content: space-between;

  padding: 18px;
  border-radius: 18px;

  text-decoration: none;
  color: #fff;
  font-size: 17px;
  font-weight: 500;

  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);

  box-shadow: 
    0 4px 20px rgba(0,0,0,0.4),
    inset 0 1px 0 rgba(255,255,255,0.05);

  transition: all 0.15s ease;
}

/* efeito toque */
li a:active {
  transform: scale(0.97);
  opacity: 0.85;
}

/* ícone à esquerda (fake via before) */
li a::before {
  content: "•";
  font-size: 22px;
  margin-right: 12px;
  opacity: 0.7;
}

/* seta estilo iOS */
li a::after {
  content: "›";
  font-size: 22px;
  opacity: 0.4;
}

/* Cores inteligentes */

li a[href*="power"] {
  background: linear-gradient(135deg, #ff3b30, #ff6b6b);
}

li a[href*="edit"] {
  background: linear-gradient(135deg, #34c759, #30d158);
}

li a[href*="settings"] {
  background: linear-gradient(135deg, #0a84ff, #5ac8fa);
}

li a[href*="save"] {
  background: linear-gradient(135deg, #ff9f0a, #ffd60a);
}

/* efeito glass em dark */
