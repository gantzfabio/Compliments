body {
  background: #0b0b0c;
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  color: #fff;
}

.container {
  max-width: 420px;
  margin: 0 auto;
  padding: 20px;
}

/* HEADER */
.header {
  text-align: center;
  font-size: 14px;
  letter-spacing: 3px;
  opacity: 0.6;
  margin-bottom: 20px;
}

/* BLOCO SUPERIOR */
.header::after {
  content: "MAGICMIRROR²";
  display: block;
  margin-top: 20px;
  padding: 18px;
  border-radius: 16px;
  background: #111;
  border: 1px solid rgba(255,255,255,0.05);
  font-size: 16px;
  letter-spacing: 2px;
}

/* MENU */
.menu {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* ESCONDER MENUS NÃO ATIVOS */
.menu .power-menu,
.menu .edit-menu,
.menu .settings-menu {
  display: none;
}

/* MENU ATIVO */
.menu .main-menu.active,
.menu .power-menu.active,
.menu .settings-menu.active,
.menu .edit-menu.active {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* ITEM */
.menu-element {
  height: 56px;
  border-radius: 14px;
  background: #111;
  border: 1px solid rgba(255,255,255,0.06);

  display: flex;
  align-items: center;
  justify-content: space-between;

  padding: 0 16px;
  font-size: 15px;
  transition: all 0.2s ease;
}

/* HOVER / TOUCH */
.menu-element:active {
  transform: scale(0.97);
  background: #1a1a1c;
}

/* TEXTO */
.text {
  flex: 1;
  text-align: left;
  margin-left: 10px;
}

/* ÍCONE ESQUERDA */
.menu-element::before {
  font-family: "FontAwesome";
