#!/bin/bash

IP="192.168.1.50"
HORA=$(date +%H)

if [ "$HORA" -ge 6 ] && [ "$HORA" -lt 23 ]; then
  if ping -c 1 $IP > /dev/null; then
    /usr/bin/vcgencmd display_power 1
  else
    /usr/bin/vcgencmd display_power 0
  fi
else
  /usr/bin/vcgencmd display_power 0
fi



